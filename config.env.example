# pco-autoclaw configuration
# Copy to config.env and fill in your values.
# Or run: bash setup.sh

# ── Church Identity ──────────────────────────────────────────────────
# Displayed on event graphics
CHURCH_NAME=Your Church Name
CHURCH_LOGO_PATH=logo_white.png

# ── Planning Center ──────────────────────────────────────────────────
# Get yours at: https://api.planningcenteronline.com/oauth/applications
PCO_APP_ID=
PCO_SECRET=

# Which service types to manage (comma-separated PCO IDs)
# Discover yours: python3 pco_client.py list-service-types
PCO_SERVICE_TYPE_IDS=

# Scheduling rules
SCHEDULE_ADVANCE_DAYS=21
SCHEDULE_MIN_DAYS_BETWEEN=14
SCHEDULE_LOOKBACK_MONTHS=6

# Telegram notifications (optional — uses send-telegram.sh)
TELEGRAM_NOTIFY=1

# ── Sunday Booklet Generator ────────────────────────────────────────
# Default Planning Center Services service type for weekly Sunday worship
BOOKLET_SERVICE_TYPE_ID=

# SQLite manifest used to track generated docs and managed sections
# Defaults to data/booklet_manifest.sqlite3 if not set
BOOKLET_MANIFEST_DB=

# Local workbook containing the liturgical planning grid for the year
BOOKLET_PLANNING_WORKBOOK=

# ── Google Workspace ─────────────────────────────────────────────────
# Service account key file (recommended for headless servers):
# 1) Enable Google Docs API + Google Drive API in GCP
# 2) Create a service account
# 3) Share template docs and output folders with it as Editor
GOOGLE_SERVICE_ACCOUNT_FILE=

# Drive folder containing pristine template docs grouped by template family
BOOKLET_GOOGLE_TEMPLATE_ROOT_ID=

# Drive folder for generated outputs
BOOKLET_GOOGLE_OUTPUT_ROOT_ID=

# Default base doc for ordinary-time-after-Pentecost services
BOOKLET_ORDINARY_TEMPLATE_DOC_ID=

# Optional Google OAuth files (use when service account can't access shared drives)
GOOGLE_OAUTH_CLIENT_SECRET_FILE=
GOOGLE_OAUTH_TOKEN_FILE=

# ── APIs ─────────────────────────────────────────────────────────────
# Crossway ESV API token: https://api.esv.org/
ESV_API_TOKEN=

# Pexels API key for stock photo backgrounds: https://www.pexels.com/api/
PEXELS_API_KEY=

# ── Booklet Customization ───────────────────────────────────────────
# Map planning worksheet initials to first names
# Format: comma-separated KEY:VALUE pairs
NAME_ALIASES=

# Extra corpus search keywords for your church (comma-separated)
BOOKLET_EXTRA_KEYWORDS=

# Extra variant markers (comma-separated, lowercase)
BOOKLET_EXTRA_VARIANT_MARKERS=

# ── Sermon Transcription ────────────────────────────────────────────
# Subsplash app key (find in any embed URL: subsplash.com/u/-APPKEY/...)
SUBSPLASH_APP_KEY=

# Whisper model size: tiny, base, small, medium, large
WHISPER_MODEL=base
