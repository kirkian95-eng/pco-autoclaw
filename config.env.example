# Planning Center Online — Personal Access Token
# Get yours at: https://api.planningcenteronline.com/oauth/applications
PCO_APP_ID=your_app_id_here
PCO_SECRET=your_secret_here

# Which service types to manage (comma-separated PCO IDs)
# Discover yours: python3 pco_client.py list-service-types
PCO_SERVICE_TYPE_IDS=

# Scheduling rules
SCHEDULE_ADVANCE_DAYS=21
SCHEDULE_MIN_DAYS_BETWEEN=14
SCHEDULE_LOOKBACK_MONTHS=6

# Telegram notifications (optional — uses send-telegram.sh)
TELEGRAM_NOTIFY=1

# ── Sunday booklet generator ──────────────────────────────────

# Default Planning Center Services service type for weekly Sunday worship
BOOKLET_SERVICE_TYPE_ID=1219410

# SQLite manifest used to track generated docs and managed sections
BOOKLET_MANIFEST_DB=/home/ubuntu/pco-autoclaw/data/booklet_manifest.sqlite3

# Local workbook containing the liturgical planning grid for the year.
BOOKLET_PLANNING_WORKBOOK=/home/ubuntu/pco-autoclaw/data/2026-planning-worksheet.xlsx

# Google service account key file. Recommended auth model:
# 1) enable Google Docs API + Google Drive API in GCP
# 2) create a service account
# 3) share the template docs and year output folders with that service account as Editor
GOOGLE_SERVICE_ACCOUNT_FILE=/home/ubuntu/pco-autoclaw/google-service-account.json

# Drive folder containing pristine template docs grouped by template family
BOOKLET_GOOGLE_TEMPLATE_ROOT_ID=

# Drive folder for generated outputs. Prefer a dedicated folder such as
# "Generated Litugries" instead of the live year folders.
BOOKLET_GOOGLE_OUTPUT_ROOT_ID=

# Default base doc for ordinary-time-after-Pentecost services
BOOKLET_ORDINARY_TEMPLATE_DOC_ID=

# Optional Google OAuth files for acting as the real Google user.
# Use this when service-account writes fail due to Drive quota.
GOOGLE_OAUTH_CLIENT_SECRET_FILE=/home/ubuntu/pco-autoclaw/google-oauth-client-secret.json
GOOGLE_OAUTH_TOKEN_FILE=/home/ubuntu/pco-autoclaw/google-oauth-token.json

# Crossway ESV API token. Do not use an unofficial mirror as source of truth.
ESV_API_TOKEN=

# Pexels API key for stock photo backgrounds in event graphics
# Get yours at: https://www.pexels.com/api/
PEXELS_API_KEY=
